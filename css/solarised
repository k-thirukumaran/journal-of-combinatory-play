/* ══════════════════════════════════════════════════════
   SOLARIZED PALETTE — exact values from Ethan Schoonover
   ══════════════════════════════════════════════════════ */

[data-theme="dark"] {
  --base03:  #002b36;
  --base02:  #073642;
  --base01:  #586e75;
  --base0:   #839496;
  --base1:   #93a1a1;
  --yellow:  #b58900;
  --orange:  #cb4b16;
  --red:     #dc322f;
  --magenta: #d33682;
  --violet:  #6c71c4;
  --blue:    #268bd2;
  --cyan:    #2aa198;
  --green:   #859900;

  --bg:                #002b36;
  --bg-highlight:      #073642;
  --bg-subtle:         #0a3442;
  --text:              #839496;
  --text-em:           #93a1a1;
  --text-head:         #93a1a1;
  --text-dim:          #586e75;
  --border:            #0e4050;
  --border-strong:     #1a5060;
  --accent:            #268bd2;
  --accent-hover:      #3a9fe2;
  --link:              #268bd2;
  --link-hover:        #2aa198;
  --code-bg:           #073642;
  --code-text:         #859900;
  --blockquote-border: #2aa198;
  --blockquote-bg:     #062e38;
  --mark:              #b58900;
  --mark-text:         #002b36;
  --table-head-bg:     #073642;
  --table-alt:         #062f3a;
  --tag-bg:            #0a3c4a;
  --tag-text:          #2aa198;
  --hr:                #073642;
  --kbd-bg:            #073642;
  --kbd-border:        #586e75;
}

[data-theme="light"] {
  --base03:  #fdf6e3;
  --base02:  #eee8d5;
  --base01:  #93a1a1;
  --base0:   #657b83;
  --base1:   #586e75;
  --yellow:  #b58900;
  --orange:  #cb4b16;
  --red:     #dc322f;
  --magenta: #d33682;
  --violet:  #6c71c4;
  --blue:    #268bd2;
  --cyan:    #2aa198;
  --green:   #859900;

  --bg:                #fdf6e3;
  --bg-highlight:      #eee8d5;
  --bg-subtle:         #f5edcc;
  --text:              #4a6168;
  --text-em:           #3a5060;
  --text-head:         #253f48;
  --text-dim:          #93a1a1;
  --border:            #d8d0b8;
  --border-strong:     #c0b89a;
  --accent:            #268bd2;
  --accent-hover:      #1a7cc0;
  --link:              #1a74bc;
  --link-hover:        #2aa198;
  --code-bg:           #e8e0cc;
  --code-text:         #7a5a00;
  --blockquote-border: #2aa198;
  --blockquote-bg:     #e8f4f2;
  --mark:              #ffe58a;
  --mark-text:         #4a3000;
  --table-head-bg:     #e0d8c4;
  --table-alt:         #f5edcc;
  --tag-bg:            #ddf2ef;
  --tag-text:          #1a7a70;
  --hr:                #d8d0b8;
  --kbd-bg:            #e8e0cc;
  --kbd-border:        #b8b098;
}

/* ══════════════════════════════════════════════════════
   RESET + BASE
   ══════════════════════════════════════════════════════ */

*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  transition: background-color 0.25s ease, border-color 0.2s ease, color 0.2s ease;
}

.no-transition * { transition: none !important; }

html {
  font-size: 18px;
  scroll-behavior: smooth;
}

body {
  font-family: 'Lora', 'Georgia', serif;
  font-weight: 400;
  line-height: 1.75;
  color: var(--text);
  background: var(--bg);
  -webkit-font-smoothing: antialiased;
  min-height: 100vh;
}

/* ══════════════════════════════════════════════════════
   SITE HEADER
   ══════════════════════════════════════════════════════ */

.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  padding: 0.75rem 0;
}

.site-header-inner {
  max-width: 800px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.site-name {
  font-family: 'Inter', sans-serif;
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
  text-decoration: none;
}
.site-name span { color: var(--cyan); }

/* ── Theme toggle widget ── */
.theme-toggle {
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 5px 12px 5px 8px;
  background: var(--bg-highlight);
  font-family: 'Inter', sans-serif;
  font-size: 0.72rem;
  font-weight: 500;
  color: var(--text-dim);
  letter-spacing: 0.04em;
  user-select: none;
}
.theme-toggle:hover { border-color: var(--border-strong); }

.toggle-track {
  width: 32px;
  height: 18px;
  border-radius: 9px;
  background: var(--border-strong);
  position: relative;
  flex-shrink: 0;
}
[data-theme="light"] .toggle-track { background: var(--blue); }

.toggle-thumb {
  position: absolute;
  top: 2px; left: 2px;
  width: 14px; height: 14px;
  border-radius: 50%;
  background: var(--bg);
}
[data-theme="light"] .toggle-thumb { transform: translateX(14px); }

.toggle-icon { font-size: 14px; }

/* ══════════════════════════════════════════════════════
   LAYOUT
   ══════════════════════════════════════════════════════ */

.page-wrapper {
  max-width: 800px;
  margin: 0 auto;
  padding: 3rem 1.5rem 5rem;
}

/* ══════════════════════════════════════════════════════
   POST HEADER
   ══════════════════════════════════════════════════════ */

.post-header {
  margin-bottom: 2.5rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--border);
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 1rem;
}

.tag {
  font-family: 'Inter', sans-serif;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--tag-text);
  background: var(--tag-bg);
  border-radius: 4px;
  padding: 3px 8px;
  text-decoration: none;
}

.post-title {
  font-family: 'Lora', serif;
  font-size: clamp(1.9rem, 5vw, 2.6rem);
  font-weight: 600;
  line-height: 1.2;
  color: var(--text-head);
  margin-bottom: 0.75rem;
  letter-spacing: -0.01em;
}

.post-subtitle {
  font-size: 1.1rem;
  font-weight: 400;
  font-style: italic;
  color: var(--text-dim);
  line-height: 1.5;
  margin-bottom: 1.25rem;
}

.post-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem 1rem;
  font-family: 'Inter', sans-serif;
  font-size: 0.8rem;
  color: var(--text-dim);
}

.meta-dot  { color: var(--border-strong); }
.author-name { font-weight: 600; color: var(--cyan); }

/* ══════════════════════════════════════════════════════
   PROSE
   ══════════════════════════════════════════════════════ */

.prose {
  font-size: 1rem;
  line-height: 1.8;
  color: var(--text);
}

.prose p { margin-block: 1.4rem; }
.prose p:first-child { margin-top: 0; }

/* Headings */
.prose h1, .prose h2, .prose h3,
.prose h4, .prose h5, .prose h6 {
  font-family: 'Lora', serif;
  font-weight: 600;
  color: var(--text-head);
  line-height: 1.25;
  margin-top: 2.5rem;
  margin-bottom: 0.75rem;
}

.prose h1 { font-size: 2rem;   border-bottom: 2px solid var(--border); padding-bottom: 0.4rem; }
.prose h2 { font-size: 1.55rem; border-bottom: 1px solid var(--border); padding-bottom: 0.3rem; }
.prose h3 { font-size: 1.25rem; color: var(--text-em); }
.prose h4 { font-size: 1.05rem; font-style: italic; color: var(--text-em); }
.prose h5 {
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--text-dim);
}
.prose h6 {
  font-family: 'Inter', sans-serif;
  font-size: 0.75rem; font-weight: 600;
  color: var(--cyan); letter-spacing: 0.06em; text-transform: uppercase;
}

/* Links */
.prose a {
  color: var(--link);
  text-decoration: underline;
  text-decoration-color: color-mix(in srgb, var(--link) 40%, transparent);
  text-underline-offset: 3px;
}
.prose a:hover { color: var(--link-hover); text-decoration-color: var(--link-hover); }

/* Inline emphasis */
.prose strong { font-weight: 600; color: var(--text-em); }
.prose em     { font-style: italic; color: var(--text-em); }
.prose mark   { background: var(--mark); color: var(--mark-text); padding: 0.05em 0.2em; border-radius: 2px; }

/* Inline code */
.prose code {
  font-family: 'JetBrains Mono', 'Courier New', monospace;
  font-size: 0.82em; font-weight: 500;
  color: var(--code-text); background: var(--code-bg);
  border-radius: 4px; padding: 0.12em 0.38em;
}

/* Code block */
.prose pre {
  font-family: 'JetBrains Mono', 'Courier New', monospace;
  font-size: 0.83rem; line-height: 1.65;
  background: var(--bg-highlight);
  border: 1px solid var(--border);
  border-left: 3px solid var(--cyan);
  border-radius: 6px;
  padding: 1.25rem 1.5rem;
  overflow-x: auto;
  margin-block: 1.75rem;
  color: var(--text);
}
.prose pre code {
  background: none; padding: 0;
  font-size: 1em; color: inherit; border-radius: 0;
}

/* Blockquote */
.prose blockquote {
  border-left: 4px solid var(--blockquote-border);
  background: var(--blockquote-bg);
  margin-block: 2rem;
  padding: 1.25rem 1.5rem;
  border-radius: 0 6px 6px 0;
  font-style: italic;
  color: var(--text-em);
}
.prose blockquote p { margin: 0; }
.prose blockquote p + p { margin-top: 0.75rem; }
.prose blockquote cite {
  display: block; margin-top: 0.75rem;
  font-size: 0.85rem; font-style: normal;
  color: var(--text-dim); font-family: 'Inter', sans-serif;
}
.prose blockquote cite::before { content: "— "; }

/* Horizontal rule */
.prose hr {
  border: none;
  border-top: 1px solid var(--hr);
  margin-block: 3rem;
  position: relative;
}
.prose hr::after {
  content: "✦";
  position: absolute; left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  background: var(--bg); padding: 0 0.75rem;
  color: var(--text-dim); font-size: 0.75rem;
}

/* Lists */
.prose ul, .prose ol { margin-block: 1.4rem; padding-left: 1.6rem; }
.prose li { margin-block: 0.4rem; }
.prose li > ul, .prose li > ol { margin-block: 0.4rem; }

.prose ul { list-style: none; }
.prose ul > li { position: relative; padding-left: 0.4rem; }
.prose ul > li::before {
  content: "▸"; position: absolute; left: -1.2rem;
  color: var(--cyan); font-size: 0.75em; top: 0.25em;
}
.prose ul ul > li::before    { content: "◦"; color: var(--text-dim); }
.prose ul ul ul > li::before { content: "–"; color: var(--text-dim); }

.prose ol { list-style: decimal; }
.prose ol > li::marker { color: var(--cyan); font-weight: 600; }

.prose ul.task-list { list-style: none; padding-left: 0.5rem; }
.prose .task-list li::before { display: none; }
.prose .task-list input[type="checkbox"] { margin-right: 0.6rem; accent-color: var(--cyan); }

/* Definition list */
.prose dl { margin-block: 1.4rem; }
.prose dt {
  font-weight: 600; color: var(--text-em);
  margin-top: 1rem; font-family: 'Inter', sans-serif;
  font-size: 0.9rem; letter-spacing: 0.02em;
}
.prose dd {
  margin-left: 1.5rem; color: var(--text);
  border-left: 2px solid var(--border);
  padding-left: 1rem; margin-top: 0.25rem;
}

/* Table */
.prose table {
  width: 100%; border-collapse: collapse; margin-block: 2rem;
  font-family: 'Inter', sans-serif; font-size: 0.87rem; line-height: 1.5;
  border: 1px solid var(--border); border-radius: 6px; overflow: hidden;
}
.prose table th {
  background: var(--table-head-bg); color: var(--text-head);
  font-weight: 600; text-align: left;
  padding: 0.7rem 1rem;
  border-bottom: 2px solid var(--border-strong);
  letter-spacing: 0.03em; white-space: nowrap;
}
.prose table td {
  padding: 0.65rem 1rem;
  border-bottom: 1px solid var(--border);
  vertical-align: top; color: var(--text);
}
.prose table tr:nth-child(even) td { background: var(--table-alt); }
.prose table tr:last-child td { border-bottom: none; }
.prose table tr:hover td { background: var(--bg-highlight); }

.table-wrap { overflow-x: auto; margin-block: 2rem; }
.table-wrap table { margin: 0; }

/* Figure */
.prose figure { margin-block: 2.5rem; text-align: center; }
.prose figure img { max-width: 100%; border-radius: 6px; border: 1px solid var(--border); }
.prose figcaption {
  font-family: 'Inter', sans-serif; font-size: 0.8rem;
  color: var(--text-dim); margin-top: 0.75rem; font-style: italic;
}

/* Keyboard */
.prose kbd {
  font-family: 'JetBrains Mono', monospace; font-size: 0.78em;
  background: var(--kbd-bg); border: 1px solid var(--kbd-border);
  border-bottom-width: 3px; border-radius: 4px;
  padding: 0.1em 0.45em; color: var(--text-em);
}

/* Abbreviation */
.prose abbr[title] {
  border-bottom: 1px dashed var(--text-dim);
  cursor: help; text-decoration: none;
}

/* Details / summary */
.prose details {
  border: 1px solid var(--border); border-radius: 6px;
  padding: 0.75rem 1rem; margin-block: 1.5rem;
  background: var(--bg-highlight);
}
.prose summary {
  cursor: pointer; font-weight: 600; color: var(--text-em);
  font-family: 'Inter', sans-serif; font-size: 0.92rem;
  list-style: none; display: flex; align-items: center; gap: 0.5rem;
}
.prose summary::before { content: "▶"; font-size: 0.65em; color: var(--cyan); }
.prose details[open] summary::before { transform: rotate(90deg); }
.prose details > *:not(summary) { margin-top: 0.75rem; }

/* Aside / callout note */
.prose aside {
  background: var(--bg-highlight); border: 1px solid var(--border);
  border-left: 4px solid var(--yellow); border-radius: 0 6px 6px 0;
  padding: 1rem 1.25rem; margin-block: 2rem;
  font-family: 'Inter', sans-serif; font-size: 0.875rem;
  color: var(--text-em); line-height: 1.65;
}
.prose aside strong { color: var(--yellow); }

/* Sup / sub */
.prose sup, .prose sub { font-size: 0.72em; }
.prose sup a { color: var(--cyan); text-decoration: none; font-weight: 600; }

/* Lead paragraph */
.prose .lead {
  font-size: 1.15rem; line-height: 1.7;
  color: var(--text-em); font-style: italic; margin-bottom: 2rem;
}

/* ══════════════════════════════════════════════════════
   CALLOUT BOXES
   ══════════════════════════════════════════════════════ */

.callout {
  display: flex; gap: 1rem; align-items: flex-start;
  padding: 1rem 1.25rem; border-radius: 6px; margin-block: 2rem;
  font-family: 'Inter', sans-serif; font-size: 0.9rem; line-height: 1.6;
}
.callout-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 0.1rem; }
.callout-body strong { display: block; margin-bottom: 0.2rem; }

.callout-info    { background: color-mix(in srgb, var(--blue)   12%, var(--bg)); border-left: 3px solid var(--blue);   color: var(--text-em); }
.callout-warning { background: color-mix(in srgb, var(--yellow) 12%, var(--bg)); border-left: 3px solid var(--yellow); color: var(--text-em); }
.callout-danger  { background: color-mix(in srgb, var(--red)    12%, var(--bg)); border-left: 3px solid var(--red);    color: var(--text-em); }
.callout-tip     { background: color-mix(in srgb, var(--cyan)   12%, var(--bg)); border-left: 3px solid var(--cyan);   color: var(--text-em); }

/* ══════════════════════════════════════════════════════
   POST FOOTER
   ══════════════════════════════════════════════════════ */

.post-footer {
  margin-top: 3.5rem; padding-top: 2rem;
  border-top: 1px solid var(--border);
}
.post-footer-label {
  font-family: 'Inter', sans-serif; font-size: 0.72rem; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--text-dim); margin-bottom: 1rem;
}
.tag-cloud { display: flex; flex-wrap: wrap; gap: 8px; }

/* ══════════════════════════════════════════════════════
   RESPONSIVE
   ══════════════════════════════════════════════════════ */

@media (max-width: 600px) {
  html { font-size: 16px; }
  .page-wrapper { padding: 2rem 1.1rem 4rem; }
  .prose pre { padding: 1rem; font-size: 0.78rem; }
  .prose h1 { font-size: 1.7rem; }
  .prose h2 { font-size: 1.3rem; }
}
